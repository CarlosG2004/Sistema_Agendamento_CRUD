# Copie este arquivo para .env e preencha os valores

# Chave secreta do Django (gere uma nova com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=django-insecure-substitua-por-uma-chave-segura

# Modo debug (True em desenvolvimento, False em produção)
DEBUG=True

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1
